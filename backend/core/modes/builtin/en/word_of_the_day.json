      "definition": {"type": "string", "default": "A happy accident or pleasant surprise"},
      "example": {"type": "string", "default": "Finding that book was pure serendipity."}
    },
    "temperature": 0.8,
    "fallback": {
      "word": "Serendipity",
      "phonetic": "/Àås…õr…ônÀàd…™p…™ti/",
      "definition": "A happy accident or pleasant surprise",
      "example": "Finding that book was pure serendipity."
    },
    "fallback_pool": [
      {
        "word": "Serendipity",
        "phonetic": "/Àås…õr…ônÀàd…™p…™ti/",
        "definition": "A happy accident or pleasant surprise",
        "example": "Finding that book was pure serendipity."
      },
      {
        "word": "Ephemeral",
        "phonetic": "/…™Ààf…õm(…ô)r…ôl/",
