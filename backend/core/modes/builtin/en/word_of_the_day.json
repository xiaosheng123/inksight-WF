    ],
    "footer": {"label": "WORD", "attribution_template": "‚Äî Expand Your Lexicon"}
  },
  "layout_overrides": {
    "296x128": {
      "body": [
        {"type": "text", "field": "word", "font_name": "Lora-Bold.ttf", "font_size": 22, "align": "center"},
