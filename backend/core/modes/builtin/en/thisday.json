{
  "mode_id": "THISDAY",
  "display_name": "On This Day",
  "icon": "thisday",
  "cacheable": true,
  "description": "A notable historical event on the same date",
  "content": {
    "type": "llm_json",
    "prompt_template": "You are a historian. Based on today's date info, select the most interesting or important event that happened on this same day (same month and day) in history.\nOutput JSON:\n{{\"year\": \"Year of the event (e.g. 1969)\", \"event_title\": \"Event title (under 30 chars)\", \"event_desc\": \"Event description (under 100 chars, vivid)\", \"years_ago\": \"How long ago (e.g. 57 years ago)\", \"significance\": \"One-line significance (under 40 chars)\"}}\nRequirements: Real historical events across science, culture, politics, sports. Avoid sensitive political topics. Different event each time. Output JSON only.\nContext: {context}",
    "output_schema": {
      "year": {"type": "string", "default": "1969"},
      "event_title": {"type": "string", "default": "Moon Landing"},
      "event_desc": {"type": "string", "default": "Apollo 11 astronauts became the first humans to walk on the Moon."},
      "years_ago": {"type": "string", "default": "57 years ago"},
      "significance": {"type": "string", "default": "Humanity's greatest leap beyond Earth."}
    },
    "temperature": 0.85,
    "fallback": {
      "year": "1969",
      "event_title": "Moon Landing",
      "event_desc": "Apollo 11 astronauts became the first humans to walk on the Moon.",
      "years_ago": "57 years ago",
      "significance": "Humanity's greatest leap beyond Earth."
    }
  },
  "layout": {
    "status_bar": { "line_width": 1, "dashed": false },
    "body": [
      { "type": "spacer", "height": 8 },
      { "type": "text", "field": "years_ago", "font_size": 11, "align": "center" },
      { "type": "big_number", "field": "year", "font_size": 38, "align": "center" },
      { "type": "separator", "style": "short", "width": 70 },
      { "type": "spacer", "height": 6 },
      { "type": "text", "field": "event_title", "font_name": "Lora-Bold.ttf", "font_size": 16, "align": "center" },
      { "type": "spacer", "height": 8 },
      { "type": "text", "field": "event_desc", "font_name": "Lora-Regular.ttf", "font_size": 13, "align": "left", "margin_x": 28, "max_lines": 4 },
      { "type": "spacer", "height": 10 },
      { "type": "separator", "style": "dashed", "margin_x": 40 },
      { "type": "spacer", "height": 6 },
      { "type": "text", "field": "significance", "font_name": "Lora-Italic.ttf", "font_size": 11, "align": "center", "max_lines": 2 }
    ],
    "footer": {
      "label": "THIS DAY",
      "attribution_template": "— History"
    }
  },
  "layout_overrides": {
    "296x128": {
      "body": [
        { "type": "text", "field": "years_ago", "font_size": 9, "align": "center" },
        { "type": "big_number", "field": "year", "font_size": 26, "align": "center" },
        { "type": "separator", "style": "short", "width": 40 },
        { "type": "text", "field": "event_title", "font_name": "Lora-Bold.ttf", "font_size": 12, "align": "center" },
        { "type": "text", "field": "event_desc", "font_size": 10, "align": "left", "margin_x": 8, "max_lines": 2 }
      ],
      "footer": { "label": "THIS DAY", "height": 18 }
    },
    "800x480": {
      "body": [
        { "type": "spacer", "height": 14 },
        { "type": "text", "field": "years_ago", "font_size": 16, "align": "center" },
        { "type": "big_number", "field": "year", "font_size": 60, "align": "center" },
        { "type": "separator", "style": "short", "width": 100 },
        { "type": "spacer", "height": 10 },
        { "type": "text", "field": "event_title", "font_name": "Lora-Bold.ttf", "font_size": 24, "align": "center" },
        { "type": "spacer", "height": 14 },
        { "type": "text", "field": "event_desc", "font_name": "Lora-Regular.ttf", "font_size": 19, "align": "left", "margin_x": 48, "max_lines": 5 },
        { "type": "spacer", "height": 16 },
        { "type": "separator", "style": "dashed", "margin_x": 60 },
        { "type": "spacer", "height": 10 },
        { "type": "text", "field": "significance", "font_name": "Lora-Italic.ttf", "font_size": 16, "align": "center", "max_lines": 3 }
      ]
    }
  }
}
