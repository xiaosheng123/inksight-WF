{
  "mode_id": "CHALLENGE",
  "display_name": "Micro Challenge",
  "icon": "flag",
  "cacheable": true,
  "description": "A quick 5-minute challenge to spark your day",
  "content": {
    "type": "llm_json",
    "prompt_template": "You are a life coach. Design a micro-challenge that can be done today in just 5 minutes, bringing a sense of freshness or small achievement.\nOutput JSON:\n{{\"challenge\": \"What to do (under 50 chars, specific and actionable)\", \"why\": \"Why it's worth doing (under 40 chars)\", \"difficulty\": \"Difficulty 1-3 stars (use ★)\", \"time\": \"Estimated time (e.g. 5 min)\"}}\nRequirements:\n1. Specific, actionable, no special tools needed\n2. Related to current weather/time if possible\n3. Cover social, creative, physical, sensory, thinking dimensions\n4. All text must be in English\nOutput JSON only.\nContext: {context}",
    "output_schema": {
      "challenge": { "type": "string", "default": "Write a 6-word story about your morning" },
      "why": { "type": "string", "default": "Constraints spark creativity" },
      "difficulty": { "type": "string", "default": "★" },
      "time": { "type": "string", "default": "5 min" }
    },
    "temperature": 0.9,
    "fallback": {
      "challenge": "Write a 6-word story about your morning",
      "why": "Constraints spark creativity",
      "difficulty": "★",
      "time": "5 min"
    }
  },
  "layout": {
    "status_bar": { "line_width": 1, "dashed": false },
    "body": [
      { "type": "spacer", "height": 8 },
      { "type": "text", "template": "Today's Challenge", "font_name": "Lora-Bold.ttf", "font_size": 14, "align": "center" },
      { "type": "text", "template": "{difficulty}  ·  {time}", "font_size": 11, "align": "center" },
      { "type": "spacer", "height": 8 },
      { "type": "separator", "style": "short", "width": 60 },
      {
        "type": "centered_text",
        "field": "challenge",
        "font_name": "Lora-Bold.ttf",
        "font_size": 18,
        "max_width_ratio": 0.8,
        "vertical_center": false,
        "line_spacing": 10
      },
      { "type": "spacer", "height": 16 },
      { "type": "separator", "style": "dashed", "margin_x": 50 },
      { "type": "spacer", "height": 6 },
      { "type": "text", "field": "why", "font_name": "Lora-Italic.ttf", "font_size": 11, "align": "center", "max_lines": 2 }
    ],
    "footer": {
      "label": "CHALLENGE",
      "attribution_template": "— Just Do It"
    }
  },
  "layout_overrides": {
    "296x128": {
      "body": [
        { "type": "text", "template": "{difficulty}  ·  {time}", "font_size": 9, "align": "center" },
        { "type": "separator", "style": "short", "width": 40 },
        {
          "type": "centered_text",
          "field": "challenge",
          "font_name": "Lora-Bold.ttf",
          "font_size": 13,
          "max_width_ratio": 0.92,
          "vertical_center": true,
          "line_spacing": 6
        }
      ],
      "footer": { "label": "CHALLENGE", "attribution_template": "— Just Do It", "height": 18 }
    },
    "800x480": {
      "body": [
        { "type": "spacer", "height": 14 },
        { "type": "text", "template": "Today's Challenge", "font_name": "Lora-Bold.ttf", "font_size": 20, "align": "center" },
        { "type": "text", "template": "{difficulty}  ·  {time}", "font_size": 15, "align": "center" },
        { "type": "spacer", "height": 12 },
        { "type": "separator", "style": "short", "width": 90 },
        {
          "type": "centered_text",
          "field": "challenge",
          "font_name": "Lora-Bold.ttf",
          "font_size": 26,
          "max_width_ratio": 0.72,
          "vertical_center": false,
          "line_spacing": 14
        },
        { "type": "spacer", "height": 24 },
        { "type": "separator", "style": "dashed", "margin_x": 80 },
        { "type": "spacer", "height": 10 },
        { "type": "text", "field": "why", "font_name": "Lora-Italic.ttf", "font_size": 16, "align": "center", "max_lines": 3 }
      ]
    }
  }
}
