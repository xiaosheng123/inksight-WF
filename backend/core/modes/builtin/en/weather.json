{
  "mode_id": "WEATHER",
  "display_name": "Weather",
  "icon": "weather",
  "cacheable": false,
  "description": "Today's weather, forecast, and practical advice",
  "settings_schema": [{"key": "forecast_days", "label": "Forecast days", "type": "number", "default": 3, "min": 1, "max": 7, "step": 1}],
  "content": {
    "type": "external_data",
    "provider": "weather_forecast",
    "fallback": {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Dress for the weather.", "forecast": []},
    "fallback_pool": [
      {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Dress for the weather.", "forecast": []},
      {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Big day-night temperature gap. Bring a jacket.", "forecast": []},
      {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Comfortable weather for a light outfit.", "forecast": []},
      {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Rain likely. Bring an umbrella.", "forecast": []},
      {"city": "", "today_temp": "--", "today_desc": "No data", "today_code": -1, "today_low": "--", "today_high": "--", "today_range": "-- / --", "today_humidity": "--", "today_wind_dir": "", "today_wind_level": "", "sunrise": "", "sunset": "", "advice": "Cold outside. Keep warm.", "forecast": []}
    ]
  },
  "layout": {
    "status_bar": {"line_width": 1, "dashed": false},
    "body_align": "top",
    "body": [
      {"type": "text", "field": "city", "font": "lora_regular", "font_size": 16, "align": "left", "margin_x": 20, "max_lines": 1},
      {"type": "spacer", "height": 8},
      {
        "type": "two_column",
        "left_width": 170,
        "gap": 6,
        "left_x": 15,
        "left": [
          {"type": "big_number", "field": "today_temp", "font_size": 52, "align": "left", "margin_x": 0, "unit": "°C"},
          {"type": "spacer", "height": 2},
          {"type": "weather_icon_text", "code_field": "today_code", "field": "today_desc", "font": "lora_regular", "font_size": 16, "icon_size": 24, "align": "left", "margin_x": 0},
          {"type": "spacer", "height": 4},
          {"type": "text", "field": "today_range", "font": "lora_regular", "font_size": 14, "align": "left", "margin_x": 0, "max_lines": 1}
        ],
        "right": [
          {"type": "forecast_cards", "field": "forecast", "max_items": 4, "margin_x": -4, "gap": 4, "icon_size": 32}
        ]
      },
      {"type": "spacer", "height": 4},
      {"type": "icon_text", "icon": "humidity", "text": "Humidity {today_humidity}%   {today_wind_dir} {today_wind_level}", "font": "lora_regular", "font_size": 12, "align": "left", "margin_x": 15},
      {"type": "spacer", "height": 4},
      {
        "type": "two_column",
        "left_width": 220,
        "gap": 4,
        "left_x": 15,
        "left": [
          {"type": "icon_text", "icon": "sunrise", "text": "Sunrise {sunrise} | Sunset {sunset}", "font": "lora_regular", "font_size": 12, "align": "left", "margin_x": 0}
        ],
        "right": []
      },
      {"type": "spacer", "height": 8},
      {"type": "separator", "style": "solid", "line_width": 1, "margin_x": 20},
      {"type": "spacer", "height": 6},
      {"type": "text", "field": "advice", "font": "lora_regular", "font_size": 12, "align": "center", "max_lines": 2}
    ],
    "footer": {"label": "WEATHER", "attribution_template": "— Open-Meteo"}
  }
}
