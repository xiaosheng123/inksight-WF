{
  "mode_id": "ALMANAC",
  "display_name": "Daily Almanac",
  "icon": "calendar",
  "cacheable": false,
  "description": "Daily wisdom with zodiac sign, lucky number, and life tip",
  "content": {
    "type": "composite",
    "steps": [
      {
        "type": "computed",
        "provider": "daily_meta",
        "fallback": {
          "year": 2026,
          "day": 1,
          "month_cn": "January",
          "weekday_cn": "Monday",
          "day_of_year": 1,
          "days_in_year": 365
        }
      },
      {
        "type": "llm_json",
        "prompt_template": "You are a daily almanac writer. Based on the date info, generate today's almanac.\nOutput JSON:\n{{\"zodiac\": \"Today's zodiac sign (e.g. Aries)\", \"element\": \"Element (Fire/Water/Earth/Air)\", \"lucky_number\": \"Lucky number (1-99)\", \"do\": \"Best thing to do today (3 items, comma-separated)\", \"avoid\": \"Things to avoid today (2 items, comma-separated)\", \"tip\": \"Life tip for today (under 30 chars)\"}}\nOutput JSON only.\nContext: {context}",
        "output_schema": {
          "zodiac": { "type": "string", "default": "Aries" },
          "element": { "type": "string", "default": "Fire" },
          "lucky_number": { "type": "string", "default": "7" },
          "do": { "type": "string", "default": "Start new projects, Exercise, Connect with friends" },
          "avoid": { "type": "string", "default": "Overthinking, Skipping meals" },
          "tip": { "type": "string", "default": "Small steps lead to big changes." }
        },
        "temperature": 0.6,
        "fallback": {
          "zodiac": "Aries",
          "element": "Fire",
          "lucky_number": "7",
          "do": "Start new projects, Exercise, Connect with friends",
          "avoid": "Overthinking, Skipping meals",
          "tip": "Small steps lead to big changes."
        }
      }
    ],
    "fallback": {}
  },
  "layout": {
    "status_bar": { "line_width": 2, "dashed": false },
    "body": [
      {
        "type": "two_column",
        "left_width": 120,
        "gap": 10,
        "left": [
          { "type": "big_number", "field": "day", "font_size": 48, "align": "center" },
          { "type": "text", "field": "weekday_cn", "font_size": 14, "align": "center", "margin_x": 8 },
          { "type": "separator", "style": "short", "width": 50 },
          { "type": "text", "field": "zodiac", "font_name": "Lora-Bold.ttf", "font_size": 14, "align": "center", "margin_x": 8 },
          { "type": "text", "template": "Lucky #{lucky_number}", "font_size": 11, "align": "center", "margin_x": 8 }
        ],
        "right": [
          { "type": "spacer", "height": 4 },
          {
            "type": "group",
            "title": "Do",
            "title_font_size": 14,
            "margin_x": 8,
            "children": [
              { "type": "text", "field": "do", "font_name": "Lora-Regular.ttf", "font_size": 13, "align": "left", "margin_x": 8, "max_lines": 2 }
            ]
          },
          { "type": "spacer", "height": 6 },
          {
            "type": "group",
            "title": "Avoid",
            "title_font_size": 14,
            "margin_x": 8,
            "children": [
              { "type": "text", "field": "avoid", "font_name": "Lora-Regular.ttf", "font_size": 13, "align": "left", "margin_x": 8, "max_lines": 2 }
            ]
          },
          { "type": "spacer", "height": 4 },
          { "type": "separator", "style": "dashed", "margin_x": 8 },
          { "type": "spacer", "height": 4 },
          { "type": "text", "field": "tip", "font_name": "Lora-Italic.ttf", "font_size": 11, "align": "left", "margin_x": 8, "max_lines": 2 }
        ]
      }
    ],
    "footer": { "label": "ALMANAC", "attribution_template": "— {element}", "line_width": 2 }
  },
  "layout_overrides": {
    "296x128": {
      "status_bar": { "line_width": 1, "dashed": false },
      "body": [
        { "type": "text", "field": "zodiac", "font_size": 11, "align": "left", "margin_x": 8, "max_lines": 1 },
        { "type": "text", "template": "{element} · Lucky #{lucky_number}", "font_size": 10, "align": "left", "margin_x": 8 },
        { "type": "separator", "style": "short", "width": 40 },
        { "type": "text", "template": "Do: {do}", "font_size": 11, "align": "left", "margin_x": 8, "max_lines": 1 },
        { "type": "text", "template": "Avoid: {avoid}", "font_size": 11, "align": "left", "margin_x": 8, "max_lines": 1 }
      ],
      "footer": { "label": "ALMANAC", "height": 20, "line_width": 1 }
    },
    "648x480": {
      "body": [
        {
          "type": "two_column",
          "left_width": 195,
          "gap": 14,
          "left": [
            { "type": "big_number", "field": "day", "font_size": 76, "align": "center" },
            { "type": "text", "field": "month_cn", "font_size": 20, "align": "center", "margin_x": 12 },
            { "type": "text", "field": "weekday_cn", "font_size": 16, "align": "center", "margin_x": 12 },
            { "type": "separator", "style": "short", "width": 80 },
            { "type": "text", "field": "zodiac", "font_name": "Lora-Bold.ttf", "font_size": 22, "align": "center", "margin_x": 12 },
            { "type": "text", "template": "Lucky #{lucky_number}", "font_size": 14, "align": "center", "margin_x": 12 }
          ],
          "right": [
            { "type": "spacer", "height": 8 },
            { "type": "group", "title": "Do", "title_font_size": 18, "margin_x": 12, "children": [
              { "type": "text", "field": "do", "font_name": "Lora-Regular.ttf", "font_size": 16, "align": "left", "margin_x": 12, "max_lines": 2 }
            ]},
            { "type": "spacer", "height": 10 },
            { "type": "group", "title": "Avoid", "title_font_size": 18, "margin_x": 12, "children": [
              { "type": "text", "field": "avoid", "font_name": "Lora-Regular.ttf", "font_size": 16, "align": "left", "margin_x": 12, "max_lines": 2 }
            ]},
            { "type": "spacer", "height": 8 },
            { "type": "separator", "style": "dashed", "margin_x": 12 },
            { "type": "spacer", "height": 8 },
            { "type": "text", "field": "tip", "font_name": "Lora-Italic.ttf", "font_size": 15, "align": "left", "margin_x": 12, "max_lines": 2 }
          ]
        }
      ]
    }
  }
}
