{
  "mode_id": "LIFEBAR",
  "display_name": "Life Progress",
  "icon": "flag",
  "cacheable": false,
  "description": "Visual progress bars for year, month, week, and life",
  "content": {
    "type": "computed",
    "provider": "lifebar",
    "fallback": {
      "year_pct": 15.6, "year_label": "2026 Year Progress",
      "month_pct": 83.3, "month_label": "Feb",
      "week_pct": 57.1, "week_label": "Week",
      "life_pct": 38.8, "life_label": "Life",
      "day_of_year": 57, "days_in_year": 365,
      "day": 25, "days_in_month": 28,
      "weekday_num": 4, "week_total": 7,
      "age": 31, "life_expect": 80
    }
  },
  "layout": {
    "status_bar": { "line_width": 1, "dashed": false },
    "body": [
      { "type": "spacer", "height": 12 },
      { "type": "text", "field": "year_label", "font_size": 12, "align": "left", "margin_x": 32 },
      { "type": "text", "template": "{year_pct}%", "font": "lora_bold", "font_size": 28, "align": "left", "margin_x": 32 },
      { "type": "progress_bar", "field": "day_of_year", "max_field": "days_in_year", "width": 336, "height": 8, "margin_x": 32 },
      { "type": "spacer", "height": 14 },
      {
        "type": "two_column",
        "left_width": 180,
        "gap": 10,
        "left": [
          { "type": "text", "field": "month_label", "font_size": 11, "align": "left", "margin_x": 32 },
          { "type": "text", "template": "{month_pct}%", "font": "lora_bold", "font_size": 20, "align": "left", "margin_x": 32 },
          { "type": "progress_bar", "field": "day", "max_field": "days_in_month", "width": 140, "height": 6, "margin_x": 32 }
        ],
        "right": [
          { "type": "text", "field": "week_label", "font_size": 11, "align": "left", "margin_x": 8 },
          { "type": "text", "template": "{week_pct}%", "font": "lora_bold", "font_size": 20, "align": "left", "margin_x": 8 },
          { "type": "progress_bar", "field": "weekday_num", "max_field": "week_total", "width": 140, "height": 6, "margin_x": 8 }
        ]
      },
      { "type": "spacer", "height": 14 },
      { "type": "separator", "style": "dashed", "margin_x": 32 },
      { "type": "spacer", "height": 6 },
      { "type": "text", "field": "life_label", "font_size": 11, "align": "left", "margin_x": 32 },
      { "type": "text", "template": "{life_pct}%", "font": "lora_bold", "font_size": 20, "align": "left", "margin_x": 32 },
      { "type": "progress_bar", "field": "age", "max_field": "life_expect", "width": 336, "height": 8, "margin_x": 32 }
    ],
    "footer": {
      "label": "LIFEBAR",
      "attribution_template": "— Time Flies"
    }
  },
  "layout_overrides": {
    "296x128": {
      "body": [
        { "type": "spacer", "height": 4 },
        { "type": "text", "field": "year_label", "font_size": 10, "align": "left", "margin_x": 8 },
        { "type": "text", "template": "{year_pct}%", "font": "lora_bold", "font_size": 20, "align": "left", "margin_x": 8 },
        { "type": "progress_bar", "field": "day_of_year", "max_field": "days_in_year", "width": 200, "height": 6, "margin_x": 8 },
        { "type": "spacer", "height": 6 },
        { "type": "text", "field": "life_label", "font_size": 10, "align": "left", "margin_x": 8 },
        { "type": "text", "template": "{life_pct}%", "font": "lora_bold", "font_size": 16, "align": "left", "margin_x": 8 },
        { "type": "progress_bar", "field": "age", "max_field": "life_expect", "width": 200, "height": 6, "margin_x": 8 }
      ],
      "footer": { "label": "LIFEBAR", "height": 20 }
    },
    "648x480": {
      "body": [
        { "type": "spacer", "height": 20 },
        { "type": "text", "field": "year_label", "font_size": 16, "align": "left", "margin_x": 50 },
        { "type": "text", "template": "{year_pct}%", "font": "lora_bold", "font_size": 42, "align": "left", "margin_x": 50 },
        { "type": "progress_bar", "field": "day_of_year", "max_field": "days_in_year", "width": 548, "height": 10, "margin_x": 50 },
        { "type": "spacer", "height": 20 },
        {
          "type": "two_column",
          "left_width": 290,
          "gap": 14,
          "left": [
            { "type": "text", "field": "month_label", "font_size": 14, "align": "left", "margin_x": 50 },
            { "type": "text", "template": "{month_pct}%", "font": "lora_bold", "font_size": 28, "align": "left", "margin_x": 50 },
            { "type": "progress_bar", "field": "day", "max_field": "days_in_month", "width": 220, "height": 8, "margin_x": 50 }
          ],
          "right": [
            { "type": "text", "field": "week_label", "font_size": 14, "align": "left", "margin_x": 12 },
            { "type": "text", "template": "{week_pct}%", "font": "lora_bold", "font_size": 28, "align": "left", "margin_x": 12 },
            { "type": "progress_bar", "field": "weekday_num", "max_field": "week_total", "width": 220, "height": 8, "margin_x": 12 }
          ]
        },
        { "type": "spacer", "height": 20 },
        { "type": "separator", "style": "dashed", "margin_x": 50 },
        { "type": "spacer", "height": 10 },
        { "type": "text", "field": "life_label", "font_size": 14, "align": "left", "margin_x": 50 },
        { "type": "text", "template": "{life_pct}%", "font": "lora_bold", "font_size": 28, "align": "left", "margin_x": 50 },
        { "type": "progress_bar", "field": "age", "max_field": "life_expect", "width": 548, "height": 10, "margin_x": 50 }
      ]
    }
  }
}
