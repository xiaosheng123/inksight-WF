# Inksight backend 
INKSIGHT_BASE_URL=

# Auth token config (prefer per-device map; fallback to single token)
INKSIGHT_ALERT_TOKEN_MAP={"AA:BB:CC:DD:EE:FF":"replace_with_real_token"}
INKSIGHT_ALERT_TOKEN=

# Focus policy gates (comma-separated)
FOCUS_VIP_USER_NAME_MAP={"$张总":"张总"}
FOCUS_VIP_USER_IDS=$张总,$李总,$运维值班长
FOCUS_URGENT_KEYWORDS=宕机,速来,线上事故,P0,全站不可用
FOCUS_MENTION_TARGETS=值班SRE,技术负责人

# Optional default target device when params.mac_address is empty
FOCUS_DEFAULT_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
